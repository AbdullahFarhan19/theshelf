<?xml version="1.0" encoding="utf-8"?>
<!-- The Full Wardrobe History Screen — A Scrollable List Of Every Item The User Has Added -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Decorative Blob In The Top-Right Corner To Match The Main Screen Aesthetic -->
    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/funky_blob"
        android:alpha="0.5"
        android:rotation="30"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Back Arrow Button — Returns The User To The Main Wardrobe Screen -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="52dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Go Back"
        app:tint="#1A1A1A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Screen Title -->
    <TextView
        android:id="@+id/tv_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="History"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textColor="#000000"
        android:layout_marginTop="60dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Subtitle Describing The Long-Press Gesture For Deletion -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Long-press an item to remove it."
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginStart="26dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_history_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Empty State Message Shown When No Items Have Been Added Yet -->
    <TextView
        android:id="@+id/tv_no_history"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your wardrobe is empty.\nAdd items with the '+' button!"
        android:textSize="15sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- The Vertically Scrolling List Of All Wardrobe Items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_history_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
