<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Decorative Blob Top-Right -->
    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/funky_blob"
        android:alpha="0.6"
        android:rotation="45"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Decorative Blob Bottom-Left -->
    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/funky_blob"
        android:alpha="0.4"
        android:rotation="-20"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="-50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- App Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Wardrobe"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textColor="#000000"
        android:layout_marginTop="60dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Item Count Subtitle — Shows How Many Items Are In The Wardrobe -->
    <TextView
        android:id="@+id/tv_item_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"
        android:layout_marginStart="26dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Empty State Hint — Visible Only When The Wardrobe Has No Items -->
    <TextView
        android:id="@+id/tv_empty_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap '+' to start adding items."
        android:textSize="16sp"
        android:textColor="#888888"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/pill_bar"
        app:layout_constraintTop_toBottomOf="@+id/tv_item_count"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Wardrobe Grid — A 2-Column RecyclerView That Fills The Space Between The Title And The Nav Bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_wardrobe"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_item_count"
        app:layout_constraintBottom_toTopOf="@+id/pill_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation Pill Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/pill_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="40dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <!-- History Icon — Left Side Of The Nav Bar -->
            <ImageView
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/ic_history"
                app:tint="#FFFFFF"
                android:contentDescription="History"
                android:clickable="true"
                android:focusable="true"/>

            <!-- Empty Space In The Center For The Floating Add Button To Sit Over -->
            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <!-- Suggestions Icon — Right Side Of The Nav Bar -->
            <ImageView
                android:id="@+id/btn_suggestions"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:src="@drawable/ic_suggestions"
                app:tint="#FFFFFF"
                android:contentDescription="Suggestions"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Floating Add Button — Sits Exactly Over The Center Of The Pill Bar -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/pill_bar"
        app:layout_constraintTop_toTopOf="@+id/pill_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer Black Ring That Creates The Border Effect Around The White Button -->
        <androidx.cardview.widget.CardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="50dp"
            app:cardBackgroundColor="#000000"
            android:layout_gravity="center">
        </androidx.cardview.widget.CardView>

        <!-- The White Tappable Add Button With The + Symbol Inside -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_add"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textSize="36sp"
                android:textColor="#000000"
                android:layout_gravity="center"
                android:layout_marginBottom="2dp"/>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
