<?xml version="1.0" encoding="utf-8"?>
<!-- The AI Outfit Suggestions Screen — Lets Users Get 3 Daily Suggestions Based On Weather And Occasion -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Decorative Blob In The Top-Right Corner -->
        <ImageView
            android:id="@+id/blob_top"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/funky_blob"
            android:alpha="0.5"
            android:rotation="-15"
            android:layout_marginTop="-40dp"
            android:layout_marginEnd="-40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back Arrow To Return To The Main Wardrobe Screen -->

        <!-- Screen Title -->

        <ImageView
            android:id="@+id/btn_back_suggestions"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:contentDescription="Go Back"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#1A1A1A" />

        <TextView
            android:id="@+id/tv_suggestions_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outfit Ideas"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#000000"
            android:layout_marginTop="60dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_suggestions_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI-powered, based on your wardrobe"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginStart="26dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_suggestions_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- ── Input Section ── -->

        <!-- Weather Input Label -->
        <TextView
            android:id="@+id/label_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY'S WEATHER"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="#888888"
            android:layout_marginTop="28dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_suggestions_subtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Weather Text Input — User Describes The Weather In Plain Text E.G. "Hot And Sunny" -->
        <EditText
            android:id="@+id/et_weather"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="e.g. Hot and sunny, 35°C"
            android:inputType="textCapSentences"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@+id/label_weather"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Occasion Input Label -->
        <TextView
            android:id="@+id/label_occasion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPECIAL OCCASION (OPTIONAL)"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="#888888"
            android:layout_marginTop="14dp"
            android:layout_marginStart="24dp"
            app:layout_constraintTop_toBottomOf="@+id/et_weather"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Occasion Text Input — User Can Describe A Special Event For Tailored Suggestions -->
        <EditText
            android:id="@+id/et_occasion"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="e.g. Job interview, wedding, casual hangout"
            android:inputType="textCapSentences"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@+id/label_occasion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Action Buttons ── -->

        <LinearLayout
            android:id="@+id/ll_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@+id/et_occasion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Primary "Get Suggestions" Button — Fires The API Call -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_get_suggestions"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.6"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="26dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardElevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Get Suggestions"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

            <!-- Refresh Button — Requests Three New Suggestions, Overwriting Today's Cache -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_refresh"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="26dp"
                app:cardBackgroundColor="#F0EBE0"
                app:cardElevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="↻  Refresh"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ── Loading / Status Area ── -->

        <!-- Spinner Shown While The API Request Is In Flight -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/ll_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Status / Error Text Shown Below The Spinner Or When An Error Occurs -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/progress_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── Suggestion Cards ── -->

        <!-- Container Holding All Three Cards — Hidden Until Suggestions Are Ready -->
        <LinearLayout
            android:id="@+id/ll_suggestions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/tv_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- "Outfit Ideas" Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY'S PICKS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="#888888"
                android:layout_marginBottom="12dp" />

            <!-- Suggestion Card 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_suggestion_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#F0EBE0"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Left: label + suggestion text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦  Outfit 1"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:textColor="#888888"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_suggestion_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                    <!-- Right: horizontal strip of item images, fixed width column -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_outfit_images_1"
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Suggestion Card 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_suggestion_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#EAF0EB"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Left: label + suggestion text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦  Outfit 2"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:textColor="#888888"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_suggestion_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                    <!-- Right: horizontal strip of item images, fixed width column -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_outfit_images_2"
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Suggestion Card 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_suggestion_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#EBE8F0"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Left: label + suggestion text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✦  Outfit 3"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:textColor="#888888"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tv_suggestion_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                    <!-- Right: horizontal strip of item images, fixed width column -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_outfit_images_3"
                        android:layout_width="80dp"
                        android:layout_height="120dp"
                        android:overScrollMode="never"
                        android:clipToPadding="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
